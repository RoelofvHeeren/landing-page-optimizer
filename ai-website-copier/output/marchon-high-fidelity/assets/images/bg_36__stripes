      for (let i = 0; i < spofBtn.length; i++) {
        spofBtn[i].style.background = wsgBtnBackground;
        spofBtn[i].style.color = wsgBtnColor;
        spofBtn[i].style.border = wsgBtnBorder;
        spofBtn[i].style.padding = wsgBtnPadding;
      }
    }

